# Database — get both from Supabase Settings → Database
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_MIGRATION_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Supabase — get from Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Session cookies
SESSION_COOKIE_NAME=bounty_session
SESSION_DURATION_DAYS=30
COOKIE_SECURE=false   # set to true in production
SESSION_SAMESITE=lax

# CSRF
CSRF_ENABLED=true

# Environment
ENVIRONMENT=development
